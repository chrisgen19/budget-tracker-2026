generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum UserRole {
  ADMIN
  FREE
  PAID
}

enum BillFrequency {
  DAILY
  WEEKLY
  MONTHLY
  ANNUALLY
  CUSTOM
}

enum BillOccurrenceStatus {
  PAID
  SKIPPED
  SNOOZED
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         UserRole      @default(FREE)
  hideAmounts             Boolean       @default(false) @map("hide_amounts")
  currency                String        @default("PHP")
  quickExpenseCategories  String[]      @default([]) @map("quick_expense_categories")
  quickIncomeCategories   String[]      @default([]) @map("quick_income_categories")
  receiptScanEnabled      Boolean       @default(false) @map("receipt_scan_enabled")
  transactionLayout       String        @default("infinite") @map("transaction_layout")
  transactions            Transaction[]
  categories              Category[]
  scanLogs                ScanLog[]
  scheduledTransactions   ScheduledTransaction[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@map("users")
}

model Category {
  id           String          @id @default(cuid())
  name         String
  type         TransactionType
  icon         String
  color        String
  isDefault    Boolean         @default(false) @map("is_default")
  userId       String?         @map("user_id")
  user         User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  scheduledTransactions ScheduledTransaction[]
  createdAt    DateTime        @default(now()) @map("created_at")

  @@unique([name, type, userId])
  @@map("categories")
}

model Transaction {
  id               String          @id @default(cuid())
  amount           Float
  description      String
  type             TransactionType
  date             DateTime
  categoryId       String          @map("category_id")
  category         Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  userId           String          @map("user_id")
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  receiptGroupId   String?         @map("receipt_group_id")
  receiptBreakdown Json?           @map("receipt_breakdown")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@index([userId, date])
  @@index([userId, type])
  @@index([receiptGroupId])
  @@map("transactions")
}

model AppSettings {
  id                 String   @id @default(cuid())
  role               UserRole @unique
  receiptScanEnabled Boolean  @default(false) @map("receipt_scan_enabled")
  maxUploadFiles     Int      @default(10) @map("max_upload_files")
  monthlyScanLimit   Int      @default(0) @map("monthly_scan_limit")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model ScanLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("scan_logs")
}

model ScheduledTransaction {
  id                  String          @id @default(cuid())
  amount              Float
  description         String          @default("")
  type                TransactionType
  frequency           BillFrequency
  customIntervalDays  Int?            @map("custom_interval_days")
  reminderDaysBefore  Int             @default(0) @map("reminder_days_before")
  startDate           DateTime        @map("start_date")
  endDate             DateTime?       @map("end_date")
  nextDueDate         DateTime        @map("next_due_date")
  isActive            Boolean         @default(true) @map("is_active")
  categoryId          String          @map("category_id")
  category            Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  userId              String          @map("user_id")
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  occurrences         ScheduledTransactionLog[]
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  @@index([userId, nextDueDate])
  @@index([userId, isActive])
  @@map("scheduled_transactions")
}

model ScheduledTransactionLog {
  id                      String                @id @default(cuid())
  scheduledTransactionId  String                @map("scheduled_transaction_id")
  scheduledTransaction    ScheduledTransaction  @relation(fields: [scheduledTransactionId], references: [id], onDelete: Cascade)
  dueDate                 DateTime              @map("due_date")
  status                  BillOccurrenceStatus
  actionDate              DateTime?             @map("action_date")
  transactionId           String?               @map("transaction_id")
  snoozeUntil             DateTime?             @map("snooze_until")
  createdAt               DateTime              @default(now()) @map("created_at")

  @@index([scheduledTransactionId, dueDate])
  @@index([scheduledTransactionId, status])
  @@map("scheduled_transaction_logs")
}
